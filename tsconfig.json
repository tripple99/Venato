{
  "compilerOptions": {
    "esModuleInterop": true,
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "noImplicitReturns": false,
    "noUnusedLocals": false,
    "rootDir": "src",
    "outDir": "dist",
    "sourceMap": true,
    "strict": false,
    "target": "es2022",
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "lib": ["es2022"],
    "typeRoots": ["./node_modules/@types", "./@types"],
    "removeComments": false
  },
  "compileOnSave": true,
  "include": ["src/**/*", "src/types/express.d.ts", "seeders/**/*"],
  "exclude": ["node_modules"],
  "files": ["./src/utils/definitions/custom.d.ts"]
}